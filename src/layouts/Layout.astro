---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noFooter?: boolean;
}

const {
  title = 'Camps Bay City Improvement District',
  description = 'Working together to preserve and enhance the exceptional quality of life in one of Cape Town\'s most beloved coastal suburbs.',
  image = '/og-image.jpg',
  noFooter = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Netlify Identity Widget for Decap CMS -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <title>{title === 'Camps Bay City Improvement District' ? title : `${title} | Camps Bay CID`}</title>
  </head>
  <body>
    <div id="password-overlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 9999; display: flex; align-items: center; justify-content: center;">
      <div style="background: white; padding: 3rem; border-radius: 12px; text-align: center; max-width: 400px;">
        <h2 style="margin: 0 0 1.5rem 0; font-family: 'Syne', sans-serif; font-size: 1.5rem; color: #20072f;">Access Protected</h2>
        <p style="margin: 0 0 1.5rem 0; color: #666; font-family: 'Nunito Sans', sans-serif;">This site is password protected. Please enter the password to continue.</p>
        <input id="password-input" type="password" placeholder="Enter password" style="width: 100%; padding: 0.75rem; margin-bottom: 1rem; border: 1px solid #ddd; border-radius: 6px; font-family: monospace; box-sizing: border-box;" />
        <button id="password-submit" style="width: 100%; padding: 0.75rem; background: #F4C430; color: #20072f; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-family: 'Nunito Sans', sans-serif;">Enter</button>
      </div>
    </div>
    <Navbar />
    <main>
      <slot />
    </main>
    {!noFooter && <Footer />}
    <script>
      // Password protection
      const correctPassword = 'Mut*e2FPwE9U^2';
      const overlay = document.getElementById('password-overlay');
      const input = document.getElementById('password-input');
      const submit = document.getElementById('password-submit');
      
      // Check if password is already stored in session storage
      if (sessionStorage.getItem('site-unlocked') === 'true') {
        overlay.style.display = 'none';
        document.body.style.overflow = 'auto';
      } else {
        document.body.style.overflow = 'hidden';
      }
      
      function checkPassword() {
        if (input.value === correctPassword) {
          sessionStorage.setItem('site-unlocked', 'true');
          overlay.style.display = 'none';
          document.body.style.overflow = 'auto';
        } else {
          input.value = '';
          input.placeholder = 'Incorrect password, try again';
          input.style.borderColor = '#ff4444';
          setTimeout(() => {
            input.placeholder = 'Enter password';
            input.style.borderColor = '#ddd';
          }, 2000);
        }
      }
      
      submit.addEventListener('click', checkPassword);
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') checkPassword();
      });
      
      // Scroll reveal for .fade-in-up elements
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.fade-in-up').forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${(i % 4) * 100}ms`;
        observer.observe(el);
      });
    </script>
  </body>
</html>
