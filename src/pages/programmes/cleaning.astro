---
import Layout from '../../layouts/Layout.astro';
const CDN = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663382560453/YLt7AD2hnj8CinfXJXi2tG';
const TEAM_GROUP_IMG = `${CDN}/cleaning_team_group_222ec8e4.jpg`;
const LANDSCAPING_IMG = `${CDN}/cleaning_landscaping_team_5b6c7d8e.jpg`;
const ROAD_MARKING_IMG = `${CDN}/cleaning_road_marking_9f0a1b2c.jpg`;
const BEACH_LITTER_IMG = `${CDN}/cleaning_beach_litter_1d2e3f4a.jpg`;
---
<Layout title="Cleaning & Urban Maintenance | Camps Bay CID" description="Our cleaning, landscaping and urban maintenance teams keep Camps Bay's streets, promenade, parks, and public spaces to the highest standard.">
  <!-- Hero -->
  <section class="relative flex items-end overflow-hidden pt-20 md:pt-[7.5rem]">
    <img src={TEAM_GROUP_IMG} alt="Camps Bay CID cleaning team in yellow uniforms" class="w-full" style="display:block;max-height:85vh;object-fit:contain;background-color:oklch(0.15 0.07 245)" />
    <div class="absolute inset-0 bg-gradient-to-t from-[oklch(0.20_0.07_245)]/90 via-[oklch(0.20_0.07_245)]/30 to-transparent pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 z-10 container pb-10 md:pb-14 text-white">
      <a href="/programmes" class="inline-flex items-center gap-1 text-[#6CCFF6] text-sm font-['Nunito_Sans'] mb-4 hover:opacity-80 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Our Programmes
      </a>
      <div class="section-label mb-3">Programme 02</div>
      <h1 class="font-['Syne'] font-800 text-4xl md:text-6xl leading-tight max-w-3xl">
        Cleaning, Landscaping &amp;<br />
        <span class="text-[#6CCFF6]">Urban Maintenance</span>
      </h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="container max-w-4xl">
      <p class="text-[oklch(0.35_0.05_245)] text-xl leading-relaxed font-['Nunito_Sans']">
        Our cleaning, landscaping and urban maintenance (CLUM) teams work tirelessly to keep Camps Bay's streets, promenade, parks, and public spaces to the highest standard. From daily litter collection to road marking and greenbelt rehabilitation, we ensure Camps Bay remains a beautiful place to live and visit.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 bg-[oklch(0.28_0.07_245)]">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white">
        {[
          { value: "2,700+", label: "Bags of litter collected monthly" },
          { value: "9", label: "Cleaning team members" },
          { value: "7", label: "Days a week operations" },
          { value: "4", label: "Operational teams deployed" },
        ].map((s) => (
          <div>
            <div class="font-['Syne'] font-800 text-3xl md:text-4xl text-[#6CCFF6]">{s.value}</div>
            <div class="text-white/70 text-sm mt-1 font-['Nunito_Sans']">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cleaning section -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="fade-in-up">
          <span class="section-label">Litter &amp; Street Cleaning</span>
          <h2 class="font-['Syne'] font-800 text-3xl text-[oklch(0.20_0.07_245)] mt-3 mb-5">Daily Cleaning Operations</h2>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-4">
            Our cleaning team of nine operates seven days a week, providing daily litter picking across main activity nodes, residential streets and public spaces.
          </p>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-5">
            During peak summer months — when Camps Bay experiences significant tourism pressure — the team expands to include both daytime and evening shifts. This ensures that litter is removed from the beachfront before wind and tidal conditions can carry waste into the ocean.
          </p>
          <ul class="space-y-2">
            {["Daily street sweeping and litter removal", "Beachfront and promenade cleaning", "Storm drain clearing and maintenance", "Graffiti removal", "Illegal dumping clearance"].map((item) => (
              <li class="flex items-center gap-3 text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-[#6CCFF6] flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="fade-in-up grid grid-cols-2 gap-4">
          <img src={BEACH_LITTER_IMG} alt="CBCID officer collecting litter at Clifton beach" class="rounded-2xl w-full h-48 object-cover" />
          <img src={LANDSCAPING_IMG} alt="Landscaping team with shovels" class="rounded-2xl w-full h-48 object-cover" />
        </div>
      </div>

      <!-- Urban Maintenance -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="fade-in-up order-2 lg:order-1">
          <img src={ROAD_MARKING_IMG} alt="CBCID Urban Maintenance officer painting road markings" class="rounded-2xl w-full h-64 object-cover" />
        </div>
        <div class="fade-in-up order-1 lg:order-2">
          <span class="section-label">Urban Maintenance</span>
          <h2 class="font-['Syne'] font-800 text-3xl text-[oklch(0.20_0.07_245)] mt-3 mb-5">Infrastructure &amp; Maintenance</h2>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-5">
            Urban Maintenance consists of six team members working in two teams, supported by a supervisor and driver. They resolve City of Cape Town C3 service requests directly within their operational capacity — significantly improving turnaround times.
          </p>
          <ul class="space-y-2">
            {["Paving and brickwork reinstatement", "Road marking and signage", "Stormwater drain maintenance", "Public furniture repair", "City C3 service request resolution"].map((item) => (
              <li class="flex items-center gap-3 text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-[#6CCFF6] flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Greenbelt -->
  <section class="py-16 bg-[oklch(0.96_0.01_245)]">
    <div class="container max-w-4xl">
      <div class="fade-in-up">
        <span class="section-label">Environmental</span>
        <h2 class="font-['Syne'] font-800 text-3xl text-[oklch(0.20_0.07_245)] mt-3 mb-5">Greenbelt &amp; Alien Vegetation</h2>
        <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-4">
          A dedicated four-person alien vegetation team works continuously to combat invasive plant growth across the suburb's greenbelts. Their ongoing efforts reduce fire risk, protect indigenous biodiversity, and stabilise environmentally sensitive slopes and river corridors.
        </p>
        <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed">
          The Eco Squad is a nine-member team focused specifically on environmental maintenance, rehabilitation and sustainability within greenbelts and public natural spaces. The team works closely with the City's Recreation and Parks Department and SANParks.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[oklch(0.28_0.07_245)]">
    <div class="container text-center text-white">
      <h3 class="font-['Syne'] font-800 text-3xl mb-4">See All Our Programmes</h3>
      <p class="text-white/70 mb-8 font-['Nunito_Sans']">Learn about our public safety and social development programmes.</p>
      <a href="/programmes" class="btn-gold inline-flex items-center gap-2">
        <span>All Programmes</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>
