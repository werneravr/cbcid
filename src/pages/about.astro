function getInitials(name: string) {
  return name.split(' ').map(n => n[0]).filter(c => /[A-Za-z]/.test(c)).slice(0, 2).join('').toUpperCase();
}
---

<Layout title="About the CID" description="Learn about the Camps Bay City Improvement District — who we are, what we do, and how we're making Camps Bay safer, cleaner, and better.">

  <!-- Hero -->
  <section class="relative h-72 md:h-96 flex items-end overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url(${ABOUT_IMG});`} />
    <div class="absolute inset-0 bg-gradient-to-t from-[oklch(0.20_0.07_245)]/90 via-[oklch(0.20_0.07_245)]/40 to-transparent" />
    <div class="relative z-10 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-12 text-white">
      <span class="section-label">Who We Are</span>
      <h1 class="font-['Syne'] font-extrabold text-4xl md:text-6xl mt-2">About the CID</h1>
    </div>
  </section>

  <!-- In-page nav -->
  <nav class="bg-[oklch(0.96_0.01_245)] border-b border-[oklch(0.90_0.01_245)] sticky top-[72px] z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-0 overflow-x-auto">
        {[
          { href: "#what-is-a-cid", label: "What is a CID?" },
          { href: "#why-camps-bay", label: "Why Camps Bay?" },
          { href: "#what-makes-us-different", label: "What Makes Us Different" },
          { href: "#team", label: "Management Team" },
          { href: "#board", label: "Board of Directors" },
          { href: "#subcommittees", label: "Subcommittees" },
        ].map(item => (
          <a href={item.href} class="font-['Syne'] font-semibold text-xs uppercase tracking-wider text-[oklch(0.45_0.04_245)] hover:text-[oklch(0.28_0.07_245)] px-4 py-4 whitespace-nowrap border-b-2 border-transparent hover:border-[#6CCFF6] transition-all">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- What is a CID -->
  <section id="what-is-a-cid" class="py-20 bg-[oklch(0.99_0.005_85)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="fade-in-up">
          <span class="section-label">Our Foundation</span>
          <h2 class="font-['Syne'] font-extrabold text-3xl md:text-4xl text-[oklch(0.20_0.07_245)] mt-3 mb-6 leading-tight">What is a City Improvement District?</h2>
          <p class="text-[oklch(0.40_0.04_245)] leading-relaxed mb-5 font-['Nunito_Sans']">A City Improvement District (CID) is a clearly defined geographical area in which property owners pay additional property rates to fund supplementary municipal services to improve or upgrade that specific area.</p>
          <p class="text-[oklch(0.40_0.04_245)] leading-relaxed mb-5 font-['Nunito_Sans']">CIDs can be commercial, industrial, residential or a combination of any of these and are known as Improvement Districts, City Improvement Districts, Business Improvement Districts, or Community Improvement Districts.</p>
          <p class="text-[oklch(0.40_0.04_245)] leading-relaxed mb-5 font-['Nunito_Sans']">The Camps Bay CID was established in 2024 (registered as NPC 2024/265642/08) in response to a noticeable decline in safety and security, and a steady increase in vagrants and criminal elements around the beachfront.</p>
          <div class="mt-4">
            <p class="font-['Syne'] font-bold text-sm uppercase tracking-widest text-[oklch(0.45_0.04_245)] mb-3">Supplementary services typically include:</p>
            <ul class="space-y-2">
              {["Additional public safety", "Cleaning services", "Urban maintenance", "Upgrading of the environment", "Social upliftment"].map(s => (
                <li class="flex items-center gap-2 text-[oklch(0.40_0.04_245)] font-['Nunito_Sans'] text-sm">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#6CCFF6] flex-shrink-0" />
                  {s}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-5">
          {[
            { title: "Safety First", desc: "Supplementary public safety patrols working alongside SAPS and Law Enforcement." },
            { title: "Accountable to You", desc: "Governed by the Municipal Property Rates Act, with full financial transparency and member oversight." },
            { title: "Community Driven", desc: "Property owners vote on the budget and elect directors from the community." },
          ].map(item => (
            <div class="fade-in-up flex gap-4 bg-[oklch(0.96_0.01_245)] rounded-xl p-5">
              <div class="w-12 h-12 rounded-full bg-[#6CCFF6] flex items-center justify-center flex-shrink-0 text-[oklch(0.20_0.07_245)] text-xl">🛡️</div>
              <div>
                <h4 class="font-['Syne'] font-bold text-[oklch(0.20_0.07_245)] mb-1">{item.title}</h4>
                <p class="text-[oklch(0.45_0.04_245)] text-sm font-['Nunito_Sans'] leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 6 Key Areas -->
  <section class="py-20 bg-[oklch(0.28_0.07_245)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">Our Focus</span>
        <h2 class="font-['Syne'] font-extrabold text-3xl md:text-4xl text-white mt-3">A CID Focuses on 6 Key Areas</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {cidAreas.map((area, i) => (
          <div class="fade-in-up bg-white/10 backdrop-blur-sm rounded-xl p-6 hover:bg-white/15 transition-colors text-center">
            <div class="w-10 h-10 rounded-full bg-[#6CCFF6] flex items-center justify-center mb-4 mx-auto text-[oklch(0.20_0.07_245)] text-lg">{area.icon}</div>
            <div class="font-['Syne'] font-extrabold text-3xl text-white/20 leading-none mb-2">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="font-['Syne'] font-bold text-white mb-2">{area.title}</h3>
            <p class="text-white/70 text-sm font-['Nunito_Sans'] leading-relaxed">{area.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Camps Bay -->
  <section id="why-camps-bay" class="py-20 bg-[oklch(0.99_0.005_85)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="fade-in-up text-center mb-12">
          <span class="section-label">Our Story</span>
          <h2 class="font-['Syne'] font-extrabold text-3xl md:text-4xl text-[oklch(0.20_0.07_245)] mt-3">Why in Camps Bay?</h2>
        </div>
        <div class="fade-in-up space-y-5 font-['Nunito_Sans'] text-[oklch(0.40_0.04_245)] leading-relaxed">
          <p>A long-term deterioration in the standard of municipal services provided to Camps Bay, together with a number of public safety incidents, motivated members of the community to investigate whether a City Improvement District (CID) should be established in Camps Bay, and in accordance with City of Cape Town requirements, a Board of Directors was established.</p>
          <p>The CID includes the beachfront and village, the Glen and Roundhouse, Rontree 1 and 2, Bakoven and the open land alongside. Camps Bay High School, Glen Country Club and Maidens Cove and adjacent open spaces, and Glen Beach bungalows are all excluded because they have already been included in the Clifton CID.</p>
          <p>The members of the CID Board of Directors are residents of Camps Bay with a track record of community service, drawn from many of the community organisations that work for Camps Bay. Members of the CID Board of Directors receive no compensation and have no special influence over decisions made for funding priorities.</p>
          <p>There are currently more than 60 CIDs successfully operating within the City of Cape Town, with the closest ones to us being Llandudno and Sea Point, and Clifton.</p>
          <p class="font-bold text-[oklch(0.20_0.07_245)]">We hope you will support us in this journey.</p>
          <p class="text-sm">— <strong>Camps Bay CID Board of Directors</strong> | <a href="mailto:connect@campsbaycid.org" class="text-[oklch(0.28_0.07_245)] hover:text-[#6CCFF6] transition-colors">connect@campsbaycid.org</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Need to Know -->
  <section id="need-to-know" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">Need to Know</span>
        <h2 class="font-['Syne'] font-extrabold text-3xl md:text-4xl text-[oklch(0.20_0.07_245)] mt-3">What Does the CID Do?</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="fade-in-up bg-[oklch(0.96_0.01_245)] rounded-2xl p-8 shadow-sm">
          <h3 class="font-['Syne'] font-extrabold text-xl text-[oklch(0.20_0.07_245)] mb-6">What the CID Does</h3>
          <ul class="space-y-3 font-['Nunito_Sans'] text-[oklch(0.40_0.04_245)] text-sm leading-relaxed">
            {[
              "24/7 security patrols using foot patrol officers, tactical vehicles and Law Enforcement officers with powers to arrest and fine",
              "24/7 control room for reporting anything: crime, suspicious activity, municipal issues",
              "Installs and monitors thermal AI and Licence Plate Recognition cameras in strategic locations throughout Camps Bay",
              "Assists SAPS in investigating crimes",
              "Provides support for victims of serious crime",
              "Dedicated professional cleaning teams deployed throughout Camps Bay",
              "Professional Urban Maintenance teams fix basic infrastructure (e.g. pot holes, drains, clearing vegetation)",
              "Environmental upgrading projects including beachfront, greenbelt areas, and rehabilitation of disused paths",
              "Social development teams assist with shelter placements, family reunifications for the homeless, and skills development programmes",
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 rounded-full bg-[#6CCFF6] flex-shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="fade-in-up bg-[oklch(0.20_0.07_245)] rounded-2xl p-8 shadow-sm">
          <h3 class="font-['Syne'] font-extrabold text-xl text-white mb-6">What the CID Does NOT Do</h3>
          <ul class="space-y-3 font-['Nunito_Sans'] text-white/75 text-sm leading-relaxed">
            {[
              "Operate on private property (refer to armed response companies such as PPA, Bay Response and FADT)",
              "Undertake large maintenance projects such as road re-surfacing, tree removal etc (refer to the City of Cape Town)",
              "Get involved in property disputes including planning regulations (refer to Camps Bay and Clifton Ratepayers Association — cbcra.co.za)",
              "Deal with moving traffic violations such as speeding vehicles (refer to City of Cape Town Traffic department)",
              "Act as a substitute for City of Cape Town municipal services",
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 rounded-full bg-[#6CCFF6] flex-shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 pt-6 border-t border-white/20 font-['Nunito_Sans'] text-white/90 text-sm leading-relaxed italic">The Camps Bay CID tops up municipal services, provides additional resources and works closely with the City to ensure property owners extract maximum value from both their municipal rates and CID levy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section id="what-makes-us-different" class="py-20 bg-[oklch(0.96_0.01_245)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 fade-in-up">
        <span class="section-label">Our Advantage</span>
        <h2 class="font-['Syne'] font-extrabold text-3xl md:text-4xl text-[oklch(0.20_0.07_245)] mt-3">What Makes Us Different?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {differentiators.map(d => (
          <div class="fade-in-up bg-white rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-['Syne'] font-extrabold text-xl text-[oklch(0.20_0.07_245)] mb-3">{d.title}</h3>
            <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed text-sm">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Management Team -->
  <section id="team" class="py-20 bg-[oklch(0.96_0.01_245)]">
