        {management.map(m => (
          <div class="fade-in-up bg-white rounded-xl p-5 text-center shadow-sm hover:shadow-md transition-shadow">
            <img src={m.photo} alt={m.name} class="w-16 h-16 rounded-full object-cover mx-auto mb-3 border-2 border-[#6CCFF6]" loading="lazy" />
            <h4 class="font-['Syne'] font-bold text-sm text-[oklch(0.20_0.07_245)] mb-1">{m.name}</h4>
            <p class="text-[#3083DC] text-xs font-['Nunito_Sans'] font-semibold mb-2">{m.role}</p>
