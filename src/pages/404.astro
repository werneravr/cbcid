---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found | Camps Bay CID" description="The page you're looking for doesn't exist.">
  <section class="min-h-screen flex items-center justify-center bg-[oklch(0.99_0.005_85)]">
    <div class="container text-center py-24">
      <div class="text-[oklch(0.85_0.05_245)] font-['Syne'] font-800 text-[8rem] leading-none mb-4">404</div>
      <h1 class="font-['Syne'] font-800 text-3xl text-[oklch(0.20_0.07_245)] mb-4">Page Not Found</h1>
      <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-gold inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Go Home</span>
        </a>
        <a href="/communications" class="btn-navy inline-flex items-center gap-2">
          <span>View Communications</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
