---
import Layout from '../../layouts/Layout.astro';
const HERO_IMG = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663382560453/YLt7AD2hnj8CinfXJXi2tG/childrens-playground-k7e8e9U5rV4S5qqgvCmUJM.png';
const DETAIL_IMG = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663382560453/YLt7AD2hnj8CinfXJXi2tG/childrens-playground-MPpBTETfFw8Pg5UQrsuF2x.webp';
---
<Layout title="Children's Playground | Camps Bay CID" description="The Camps Bay CID's Children's Playground project creates an inclusive, accessible play space for families in Camps Bay.">
  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[400px] flex items-end overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image:url(${HERO_IMG})`}></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[oklch(0.20_0.07_245)]/90 via-[oklch(0.20_0.07_245)]/30 to-transparent"></div>
    <div class="relative z-10 container pb-10 md:pb-14 text-white">
      <a href="/projects" class="inline-flex items-center gap-1 text-[#6CCFF6] text-sm font-['Nunito_Sans'] mb-4 hover:opacity-80 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Our Projects
      </a>
      <div class="section-label mb-3">Project</div>
      <h1 class="font-['Syne'] font-800 text-4xl md:text-6xl leading-tight">
        Children's <span class="text-[#6CCFF6]">Playground</span>
      </h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="fade-in-up">
          <span class="section-label">Community Spaces</span>
          <h2 class="font-['Syne'] font-800 text-3xl text-[oklch(0.20_0.07_245)] mt-3 mb-5">Play for Every Child</h2>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-4">
            The Children's Playground is a vibrant, inclusive community space designed to bring families together and provide safe, engaging play opportunities for children of all ages and abilities.
          </p>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] leading-relaxed mb-5">
            This project reflects our commitment to making Camps Bay a welcoming place for families. The playground features modern, accessible equipment, sensory play areas for children with different needs, and shaded rest zones for caregivers.
          </p>
          <ul class="space-y-2">
            {["Accessible play equipment", "Sensory play stations", "Shade structures and seating", "Safety surfacing", "Family-friendly amenities"].map((item) => (
              <li class="flex items-center gap-3 text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-[#6CCFF6] flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="fade-in-up">
          <img src={DETAIL_IMG} alt="Children's Playground" class="rounded-2xl w-full h-auto object-cover" />
        </div>
      </div>

      <!-- Features Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20 pt-16 border-t border-[oklch(0.88_0.01_245)]">
        <div class="fade-in-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-[#6CCFF6] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.20_0.07_245)]"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <h3 class="font-['Syne'] font-700 text-[oklch(0.20_0.07_245)]">Inclusive Design</h3>
          </div>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm leading-relaxed">
            Equipment and spaces designed to welcome children with different abilities, ensuring every child can play and have fun.
          </p>
        </div>

        <div class="fade-in-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-[#6CCFF6] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.20_0.07_245)]\"><path d="M17 8C8 10 5.9 16.17 3.82 21.34A1 1 0 0 0 4.8 22.5h14.4a1 1 0 0 0 .98-1.16C19.39 17.16 17 8 17 8z"/><path d="M17 8l-2.5-5"/></svg>
            </div>
            <h3 class="font-['Syne'] font-700 text-[oklch(0.20_0.07_245)]">Safe Environment</h3>
          </div>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm leading-relaxed">
            Modern safety surfacing, regular maintenance, and thoughtful design ensure children can play safely and parents can relax.
          </p>
        </div>

        <div class="fade-in-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-[#6CCFF6] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.20_0.07_245)]\"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4.25 2.52"/></svg>
            </div>
            <h3 class="font-['Syne'] font-700 text-[oklch(0.20_0.07_245)]">Community Hub</h3>
          </div>
          <p class="text-[oklch(0.45_0.04_245)] font-['Nunito_Sans'] text-sm leading-relaxed">
            A gathering place for families to connect, build friendships, and strengthen the bonds that make Camps Bay a vibrant community.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[oklch(0.28_0.07_245)]">
    <div class="container text-center text-white">
      <h3 class="font-['Syne'] font-800 text-3xl mb-4">See All Projects</h3>
      <a href="/projects" class="btn-gold inline-flex items-center gap-2">
        <span>All Projects</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>
